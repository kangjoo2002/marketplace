{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "productId": {
        "type": "long"
      },
      "sellerId": {
        "type": "long"
      },
      "categoryId": {
        "type": "long"
      },
      "brandId": {
        "type": "long"
      },
      "status": {
        "type": "keyword"
      },
      "price": {
        "type": "integer"
      },
      "rating": {
        "type": "scaled_float",
        "scaling_factor": 100
      },
      "reviewCount": {
        "type": "integer"
      },
      "createdAt": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss"
      },
      "updatedAt": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss"
      },
      "sourceUpdatedAt": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss"
      },
      "documentRefreshedAt": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss"
      },
      "options": {
        "type": "nested",
        "properties": {
          "color": {
            "type": "keyword"
          },
          "size": {
            "type": "keyword"
          },
          "stockStatus": {
            "type": "keyword"
          }
        }
      }
    }
  }
}
